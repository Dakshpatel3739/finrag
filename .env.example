# =============================================================================
# FinRAG — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# NVIDIA NIM
# Single API key used for all three NIM microservices (embedding, reranking, LLM).
# Obtain free credits at https://build.nvidia.com
# -----------------------------------------------------------------------------
NIM_API_KEY=nvapi-<your-key-here>

# Base URLs for each NIM service (no trailing slash).
#
# "hosted" mode (DEPLOY_MODE=hosted):
#   All three point to NVIDIA's hosted inference API — no GPU required, free credits.
NIM_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_RERANK_BASE_URL=https://integrate.api.nvidia.com/v1

# "self_hosted" mode (DEPLOY_MODE=self_hosted, Phase 5 EKS GPU cluster):
#   Override the URLs above to point at your cluster's NIM services, e.g.:
# NIM_LLM_BASE_URL=http://nim-llm-service:8000/v1
# NIM_EMBED_BASE_URL=http://nim-embed-service:8000/v1
# NIM_RERANK_BASE_URL=http://nim-rerank-service:8000/v1

# Model identifiers passed to the NIM endpoint (change only if you deploy different models)
NIM_LLM_MODEL=meta/llama-3.1-8b-instruct
NIM_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
NIM_RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3

# -----------------------------------------------------------------------------
# Milvus
# Renamed from MILVUS_URI / MILVUS_COLLECTION to avoid pymilvus's import-time
# global (Connections()) picking up the env var and rejecting the Milvus Lite
# file path with ConnectionConfigException (it expects http[s]://...).
#
# Milvus Lite (dev, no server needed) — set to a local file path:
#   FINRAG_MILVUS_URI=milvus_finrag.db
#
# Self-hosted Milvus server (Phase 5 / Mode A):
#   FINRAG_MILVUS_URI=http://milvus-service:19530
#
# Zilliz Cloud (managed, always-on / Mode B):
#   FINRAG_MILVUS_URI=https://<cluster-id>.api.gcp-us-west1.zillizcloud.com
# -----------------------------------------------------------------------------
FINRAG_MILVUS_URI=milvus_finrag.db
FINRAG_MILVUS_COLLECTION=finrag_chunks

# -----------------------------------------------------------------------------
# Deploy mode
# "hosted"      — use NVIDIA hosted NIM API (dev, Mode B always-on)
# "self_hosted" — use self-hosted NIM cluster (Phase 5 GPU burst)
# -----------------------------------------------------------------------------
DEPLOY_MODE=hosted

# -----------------------------------------------------------------------------
# Auth  (Phase 3 — JWT identity enforcement)
# MUST change JWT_SECRET before any production deployment.
# The app will REFUSE to start if JWT_SECRET is the placeholder or < 32 chars.
#
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# JWT_EXPIRY_SECONDS: access token lifetime in seconds.
#   Short = safer (stolen token expires quickly).  Default: 1800 (30 min).
#   TODO (Phase 3 UI slice): add refresh tokens for seamless re-authentication.
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=1800

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
